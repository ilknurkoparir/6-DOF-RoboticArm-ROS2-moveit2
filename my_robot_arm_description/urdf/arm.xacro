<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_width" value="0.4" />
    <xacro:property name="base_length" value="0.4" />
    <xacro:property name="base_height" value="0.1" />

    <xacro:property name="shoulder_length" value="0.5" />
    <xacro:property name="shoulder_radius" value="0.1" />

    <xacro:property name="arm_length" value="0.6" />
    <xacro:property name="arm_radius" value="0.05" />

    <xacro:property name="elbow_length" value="0.1" />
    <xacro:property name="elbow_radius" value="0.05" />

    <xacro:property name="forearm_length" value="0.5" />
    <xacro:property name="forearm_radius" value="0.05" />

    <xacro:property name="wrist_width" value="0.1" />
    <xacro:property name="wrist_length" value="0.1" />
    <xacro:property name="wrist_height" value="0.05" />

    <xacro:property name="hand_width" value="0.1" />
    <xacro:property name="hand_length" value="0.1" />
    <xacro:property name="hand_height" value="0.02" />

    <link name="base_link">
        <visual>
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
            <geometry>
                <box size="${base_width} ${base_length} ${base_height}" />
            </geometry>
            <material name="grey" />
        </visual>
        <collision>
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
            <geometry>
                <box size="${base_width} ${base_length} ${base_height}" />
            </geometry>
        </collision>
        <xacro:box_inertial m = "5.0" l = "${base_length}"
                                      w = "${base_width}"
                                      h = "${base_height}"
                                      xyz="0 0 ${base_height/2}"
                                      rpy = "0 0 0" />
    </link>

    <link name="shoulder_link">
        <visual>
            <origin xyz="0 0 ${(shoulder_length/2)}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${shoulder_length}" radius="${shoulder_radius}" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0 0 ${(shoulder_length/2)}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${shoulder_length}" radius="${shoulder_radius}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertial m = "5.0" 
                                 l = "${shoulder_length}"
                                 r = "${shoulder_radius}"
                                 xyz="0 0 ${(shoulder_length/2)}"
                                 rpy = "0 0 0" />
    </link>


    <joint name="base_to_shoulder_joint" type="revolute">
        <parent link="base_link" />
        <child link="shoulder_link" />
        <origin xyz="0 0 ${base_height}" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-3.14" upper="3.14" />
    </joint>


    <link name="arm_link">
        <visual>
            <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${arm_length}" radius="${arm_radius}" />
            </geometry>
            <material name="grey" />
        </visual>
        <collision>
            <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${arm_length}" radius="${arm_radius}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertial m = "5.0" 
                                 l = "${arm_length}"
                                 r = "${arm_radius}"
                                 xyz="0 0 ${arm_length/2}"
                                 rpy = "0 0 0" />
    </link>

    <joint name="shoulder_to_arm_joint" type="revolute">
        <parent link="shoulder_link" />
        <child link="arm_link" />
        <origin xyz="0 0 ${shoulder_length}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="0" upper="2.5" />
    </joint>


    <link name="elbow_link">
        <visual>
            <origin xyz="0 0 ${elbow_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${elbow_length}" radius="${elbow_radius}" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0 0 ${elbow_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${elbow_length}" radius="${elbow_radius}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertial m = "5.0" 
                                 l = "${elbow_length}"
                                 r = "${elbow_radius}"
                                 xyz="0 0 ${elbow_length/2}"
                                 rpy = "0 0 0" />
    </link>

    <joint name="arm_to_elbow_joint" type="revolute">
        <parent link="arm_link" />
        <child link="elbow_link" />
        <origin xyz="0 0 ${arm_length}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="0" upper="2.5" />
    </joint>

    <link name="forearm_link">
        <visual>
            <origin xyz="0 0 ${forearm_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${forearm_length}" radius="${forearm_radius}" />
            </geometry>
            <material name="grey" />
        </visual>
        <collision>
            <origin xyz="0 0 ${forearm_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder length="${forearm_length}" radius="${forearm_radius}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertial m = "5.0" 
                                 l = "${forearm_length}"
                                 r = "${forearm_radius}"
                                 xyz="0 0 ${forearm_length/2}"
                                 rpy = "0 0 0" />
    </link>

    <joint name="elbow_to_forearm_joint" type="revolute">
        <parent link="elbow_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 ${elbow_length}" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-3.14" upper="3.14" />
    </joint>

   <link name="wrist_link">
        <visual>
            <origin xyz="0 0 ${wrist_height/2}" rpy="0 0 0" />
            <geometry>
                <box size="${wrist_width} ${wrist_length} ${wrist_height}" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0 0 ${wrist_height/2}" rpy="0 0 0" />
            <geometry>
                <box size="${wrist_width} ${wrist_length} ${wrist_height}" />
            </geometry>
        </collision>
        <xacro:default_inertial z_value="0" i_value="1e-6" mass="1"/>
    </link>

    <joint name="forearm_to_wrist_joint" type="revolute">
        <parent link="forearm_link" />
        <child link="wrist_link" />
        <origin xyz="0 0 ${forearm_length}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
    </joint>

    <link name="hand_link">
        <visual>
            <origin xyz="0 0 ${hand_height/2}" rpy="0 0 0" />
            <geometry>
                <box size="${hand_width} ${hand_length} ${hand_height}" />
            </geometry>
            <material name="grey" />
        </visual>
        <collision>
            <origin xyz="0 0 ${hand_height/2}" rpy="0 0 0" />
            <geometry>
                <box size="${hand_width} ${hand_length} ${hand_height}" />
            </geometry>
        </collision>
        <xacro:default_inertial z_value="0" i_value="1e-6" mass="1"/>
    </link>

    <joint name="wrist_to_hand_joint" type="continuous">
        <parent link="wrist_link" />
        <child link="hand_link" />
        <origin xyz="0 0 ${wrist_height}" rpy="0 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="tool_link" />

    <joint name="hand_to_tool_joint" type="fixed">
        <parent link="hand_link" />
        <child link="tool_link" />
        <origin xyz="0 0 ${hand_height}" rpy="0 0 0" />
    </joint>


</robot>